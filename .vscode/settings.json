{
    "latex-workshop.latex.tools": [
        {
            "name": "xelatex",
            "command": "xelatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "-shell-escape",
                "%DOC%"
            ]
        },
        {
            "name": "bibtex",
            "command": "cmd",
            "args": [
                "/c",
                "if exist \"%DOCFILE%.aux\" (findstr /c:\"\\citation{\" \"%DOCFILE%.aux\" >nul && bibtex \"%DOCFILE%\" || echo Skip bibtex: no citations.) else (echo Skip bibtex: no aux file.)"
            ]
        }
    ],
    "latex-workshop.latex.recipes": [
        {
            "name": "xelatex + bibtex + xelatex x 2",
            "tools": [
                "xelatex",
                "bibtex",
                "xelatex",
                "xelatex"
            ]
        },
        {
            "name": "xelatex (fast)",
            "tools": [
                "xelatex"
            ]
        }
    ],
    "latex-workshop.latex.recipe.default": "xelatex + bibtex + xelatex x 2"
}
