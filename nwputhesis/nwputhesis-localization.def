  {
    \renewcommand{\figurename}{еӣҫ}                          %
    \renewcommand{\figureautorefname}{еӣҫ}                   %
    \renewcommand{\tablename}{иЎЁ}                           %
    \renewcommand{\tableautorefname}{иЎЁ}                    %
    \renewcommand{\bibname}{еҸӮиҖғж–ҮзҢ®}                       %
    \nwpu_if_bachelor:TF                                    % жң¬з§‘и®әж–Үзӣ®еҪ•ж Үйўҳ
      {
        \renewcommand{\contentsname}{\bfseries зӣ®~еҪ•}       %
        \renewcommand{\listfigurename}{жҸ’еӣҫеҲ—иЎЁ}            %
        \renewcommand{\listtablename}{иЎЁж јеҲ—иЎЁ}             %
      }
      {                                                    % зЎ•еҚҡи®әж–Үзӣ®еҪ•ж Үйўҳ
        \renewcommand{\contentsname}{зӣ®{\quad}еҪ•}           %
        \renewcommand{\listfigurename}{еӣҫзӣ®еҪ•}              %
        \renewcommand{\listtablename}{иЎЁзӣ®еҪ•}               %
      }
    \renewcommand{\appendixautorefname}{йҷ„еҪ•}               %
    \nwpu_if_bachelor:TF
      { \def\equationautorefname#1#2\null{ејҸ#1пјҲ#2\nullпјү} }
      { \def\equationautorefname#1#2\null{ејҸ#1(#2\null)}   }
    \def\sectionautorefname#1#2\null{#2\null{ }иҠӮ}          %
    \def\subsectionautorefname#1#2\null{#2\null{ }е°ҸиҠӮ}     %
    \renewcommand{\theoremautorefname}{е®ҡзҗҶ}                %
    \cs_new_protected:Npn \axiomautorefname {е…¬зҗҶ}          %
    \cs_new_protected:Npn \corollaryautorefname {жҺЁи®ә}      %
    \cs_new_protected:Npn \lemmaautorefname {еј•зҗҶ}          %
    \cs_new_protected:Npn \definitionautorefname {е®ҡд№ү}     %
    \cs_new_protected:Npn \exampleautorefname {дҫӢ}          %
    \cs_new_protected:Npn \propositionautorefname {е‘Ҫйўҳ}    %
    \cs_new_protected:Npn \algorithmname {з®—жі•}             %
    \cs_new_protected:Npn \algorithmautorefname {з®—жі•}      %
    \floatname{algorithm}{з®—жі•}                             %
    \renewcommand{\lstlistingname}{д»Јз ҒзүҮж®ө}                %
    \cs_new_protected:Npn \lstlistingautorefname {д»Јз ҒзүҮж®ө} %
    \renewcommand{\nomname}{з¬ҰеҸ·иЎЁ}                         %
  }
  {                                                        % иӢұж–Үеј•з”ЁжҸҗзӨәж–Үеӯ—
    \renewcommand{\figureautorefname}{Fig.}                 %
    \renewcommand{\tableautorefname}{Table}                 %
    \def\equationautorefname#1#2\null{Eq.#1(#2\null)}       %
    \renewcommand{\lstlistingname}{Code~Snippet}            %
    \cs_new_protected:Npn \lstlistingautorefname {Code~Snippet} %
    \renewcommand{\nomname}{Symbols}                        %
  }
