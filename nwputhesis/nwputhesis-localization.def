\renewcommand{\chaptername}{з¬¬~\thechapter~з« }              % з« иҠӮеҗҚ
\renewcommand{\thefigure}{\thechapter-\arabic{figure}}      % еӣҫзј–еҸ·ж јејҸ
\renewcommand{\thesubfigure}{(\alph{subfigure})}            % еӯҗеӣҫзј–еҸ·ж јејҸ
\renewcommand{\thetable}{\thechapter-\arabic{table}}        % иЎЁзј–еҸ·ж јејҸ
\renewcommand{\thealgorithm}{\thechapter-\arabic{algorithm}}% з®—жі•зј–еҸ·ж јејҸ
\@addtoreset{algorithm}{chapter}                            % жҢүз« иҠӮзј–еҸ·
\renewcommand{\theequation}{\thechapter-\arabic{equation}}  % е…¬ејҸзј–еҸ·ж јејҸ
\nwpu_if_bachelor:TF                                        % жң¬з§‘е…¬ејҸзј–еҸ·ж ·ејҸ
  { \def\tagform@#1{\maketag@@@{\fSong пјҲ#1пјү}} }
  {}
\renewcommand{\thetheorem}{\thechapter.\arabic{theorem}}    % е®ҡзҗҶзј–еҸ·ж јејҸ
\renewcommand{\theaxiom}{\thechapter.\arabic{axiom}}        % е…¬зҗҶзј–еҸ·ж јејҸ
\renewcommand{\thecorollary}{\thechapter.\arabic{corollary}}% жҺЁи®әзј–еҸ·ж јејҸ
\renewcommand{\thelemma}{\thechapter.\arabic{lemma}}        % еј•зҗҶзј–еҸ·ж јејҸ
\renewcommand{\thedefinition}{\thechapter.\arabic{definition}} % е®ҡд№үзј–еҸ·ж јејҸ
\renewcommand{\theexample}{\thechapter.\arabic{example}}    % дҫӢеӯҗзј–еҸ·ж јејҸ
