\cs_new_protected:Npn \nwpu@chs@schoolname {иҘҝеҢ—е·ҘдёҡеӨ§еӯҰ}   % ж–ҮжЎЈеӯ—з¬ҰдёІи®ҫзҪ®
\cs_new_protected:Npn \nwpu@eng@schoolname {Northwestern~Polytechnical~University}
\nwpu_if_phd:TF                                             % еҚҡеЈ«еӯҰдҪҚеҗҚ
  {
    \cs_new_protected:Npn \nwpu@chs@degree {еҚҡеЈ«}           %
    \cs_new_protected:Npn \nwpu@eng@degree {Doctor}         %
  }
  {
    \nwpu_if_master:TF                                       % зЎ•еЈ«еӯҰдҪҚеҗҚ
      {
        \cs_new_protected:Npn \nwpu@chs@degree {зЎ•еЈ«}       %
        \cs_new_protected:Npn \nwpu@eng@degree {Master}     %
      }
      {                                                     % еӯҰеЈ«еӯҰдҪҚеҗҚ
        \cs_new_protected:Npn \nwpu@chs@degree {еӯҰеЈ«}       %
        \cs_new_protected:Npn \nwpu@eng@degree {Bachelor}   %
      }
  }
\nwpu_if_bachelor:TF                                        % жң¬з§‘зү№ж®Ҡи®ҫзҪ®
  {
    \cs_new_protected:Npn \nwpu@chs@doctitle {жң¬з§‘жҜ•дёҡи®ҫи®Ўи®әж–Ү} % ж–ҮжЎЈеҗҚе’ҢйЎөзңү
    \cs_new_protected:Npn \nwpu@chs@header {{\nwpu@chs@schoolname}жң¬з§‘жҜ•дёҡи®ҫи®Ўи®әж–Ү}
  }
  {                                                         % е…¶д»–йЎөзңүз»ҹдёҖи®ҫзҪ®
    \cs_new_protected:Npn \nwpu@chs@doctitle {{\nwpu@chs@degree}еӯҰдҪҚи®әж–Ү}
    \cs_new_protected:Npn \nwpu@chs@header {\nwpu@chs@schoolname\nwpu@chs@doctitle}
  }
\nwpu_if_academic:TF                                        % жҺ§еҲ¶еҶ…е°ҒжЁЎжқҝзҡ„йҰ–йЎ№еҗҚз§°
  {
    \cs_new_protected:Npn \nwpu@chs@innerCoverFirstOption {еӯҰз§‘дё“дёҡ}  % еӯҰжңҜеӯҰдҪҚ
    \cs_new_protected:Npn \nwpu@chs@outerCoverFirstOption {еӯҰ{\enspace}з§‘{\enspace}дё“{\enspace}дёҡ}
  }
  {
    \cs_new_protected:Npn \nwpu@chs@innerCoverFirstOption {дё“дёҡйўҶеҹҹ}  % дё“дёҡеӯҰдҪҚ
    \cs_new_protected:Npn \nwpu@chs@outerCoverFirstOption {дё“{\enspace}дёҡ{\enspace}йўҶ{\enspace}еҹҹ}
  }
\cs_new_protected:Npn \nwpu@eng@doctitle {\nwpu@eng@degree~Thesis} % иӢұж–Үж–ҮжЎЈеҗҚе’ҢйЎөзңү
\cs_new_protected:Npn \nwpu@eng@header {\nwpu@eng@doctitle~of~\nwpu@eng@schoolname}

