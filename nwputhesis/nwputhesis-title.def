\cs_new_protected:Npn \__nwpu_cover_cell:nnnnn #1#2#3#4#5
  { \parbox[#1][#3][#2]{#4}{\centering #5\par} }
\cs_new_protected:Npn \__nwpu_cover_bottom_cell:nnn #1#2#3
  { \__nwpu_cover_cell:nnnnn { b } { b } {#2} {#1} {#3} }
\cs_new_protected:Npn \__nwpu_cover_visual_bottom_cell:nnn #1#2#3
  {
    \__nwpu_cover_cell:nnnnn { c } { b } {#2} {#1}
      { #3 \vspace{ \l__nwpu_cover_visual_bottom_raise_dim } }
  }
\cs_new_protected:Npn \__nwpu_cover_center_cell:nnn #1#2#3
  { \__nwpu_cover_cell:nnnnn { c } { c } {#2} {#1} {#3} }
\cs_new_protected:Npn \__nwpu_cover_title_row:nn #1#2
  {
    #1 & \__nwpu_cover_visual_bottom_cell:nnn
      { \l__nwpu_cover_title_value_width_dim }
      { \l__nwpu_cover_title_row_height_dim }
      {#2}
    \tabularnewline \cline{2-2}
  }
\cs_new_protected:Npn \__nwpu_cover_author_row:n #1
  {
    \__nwpu_cover_visual_bottom_cell:nnn
      { \l__nwpu_cover_author_label_width_dim }
      { \l__nwpu_cover_author_row_height_dim }
      { \bfseries 作者 }
    & \__nwpu_cover_visual_bottom_cell:nnn
      { \l__nwpu_cover_author_value_width_dim }
      { \l__nwpu_cover_author_row_height_dim }
      { \bfseries #1 }
    \tabularnewline \cline{2-2}
  }
\cs_new_protected:Npn \__nwpu_cover_info_row:nn #1#2
  {
    \__nwpu_cover_visual_bottom_cell:nnn
      { \l__nwpu_cover_info_label_width_dim }
      { \l__nwpu_cover_info_row_height_dim }
      { \bfseries #1 }
    & \__nwpu_cover_center_cell:nnn
      { \l__nwpu_cover_info_value_width_dim }
      { \l__nwpu_cover_info_row_height_dim }
      { \bfseries #2 }
    \tabularnewline \cline{2-2}
  }
\cs_new_protected:Npn \__nwpu_chs_inner_title_row:nn #1#2
  {
    #1 & \__nwpu_cover_visual_bottom_cell:nnn
      { \l__nwpu_chs_inner_title_value_dim }
      { \l__nwpu_chs_inner_title_row_height_dim }
      {#2}
    \tabularnewline \cline{2-2}
  }
\cs_new_protected:Npn \__nwpu_chs_inner_title:
  {
    \begin{tabular}[b]{@{}c@{}c@{}}
      \__nwpu_chs_inner_title_row:nn
        {
          \__nwpu_cover_visual_bottom_cell:nnn
            { \l__nwpu_chs_inner_title_label_width_dim }
            { \l__nwpu_chs_inner_title_row_height_dim }
            { 题目： }
        }
        { \nwpu@chs@coverTitleLineA }
      \__nwpu_chs_inner_title_row:nn { } { \nwpu@chs@coverTitleLineB }
    \end{tabular}
  }
\cs_new_protected:Npn \__nwpu_chs_inner_info_row:nn #1#2
  {
    \__nwpu_cover_visual_bottom_cell:nnn
      { \l__nwpu_chs_inner_info_label_width_dim }
      { \l__nwpu_chs_inner_info_row_height_dim }
      {#1}
    & \__nwpu_cover_visual_bottom_cell:nnn
      { \l__nwpu_chs_inner_info_value_dim }
      { \l__nwpu_chs_inner_info_row_height_dim }
      {#2}
    \tabularnewline \cline{2-2}
  }
\cs_new_protected:Npn \__nwpu_chs_inner_info:
  {
    \begin{tabular}[b]{@{}c@{}c@{}}
      \__nwpu_chs_inner_info_row:nn
        { \nwpu@chs@innerCoverFirstOption： }
        { \nwpu@chs@major }
      \__nwpu_chs_inner_info_row:nn
        { 作{\qquad}者： }
        { \makebox[\l__nwpu_maxname_dim][s]{\nwpu@chs@author} }
      \__nwpu_chs_inner_info_row:nn
        { 指导教师： }
        { \makebox[\l__nwpu_maxname_dim][s]{\nwpu@chs@advisor} }
    \end{tabular}
  }

%% 封皮页
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \make@nwpu@coverpage {                          % 设置封皮页
    \thispagestyle{empty}                                   % 清空页面格式
    \begin{titlepage}                                       %
        % 彩色封面背景图
        \nwpu_if_colorcover:TF {
            \begin{tikzpicture}[remember picture,overlay]
                \node[at=(current page.center),inner sep=\l__nwpu_cover_background_inner_sep_dim] {
                    \nwpu_if_phd:TF {
                        \includegraphics[width=\paperwidth,height=\paperheight]{cover-phd.jpg}
                    } {
                        \nwpu_if_bachelor:TF {
                            \includegraphics[width=\paperwidth,height=\paperheight]{cover-bachelor.jpg}
                        } {
                            \nwpu_if_academic:TF {
                                \includegraphics[width=\paperwidth,height=\paperheight]{cover-master-academic.jpg}
                            } {
                                \includegraphics[width=\paperwidth,height=\paperheight]{cover-master-professional.jpg}
                            }
                        }
                    }
                };
            \end{tikzpicture}
        }
        \bfseries                                           %
        \linespread{1.25}\selectfont                        % 1.25 倍行距
        \begin{center}                                      %
            \hfill \fHei \sWuhao                            %
            \begin{tabular}{
                |>{\centering\arraybackslash}p{\l__nwpu_cover_detail_label_width_dim}|
                 >{\centering\arraybackslash}p{\l__nwpu_cover_detail_value_width_dim}|
              }\hline %
                \makebox[\__nwpu_cover_detail_label_text_width:][s]{学\hfil 校\hfil 代\hfil 码} & \nwpu@schoolcode    \\ \hline
                \makebox[\__nwpu_cover_detail_label_text_width:][s]{分\hfil 类\hfil 号}          & \nwpu@classnumber   \\ \hline
                \makebox[\__nwpu_cover_detail_label_text_width:][s]{密\hfil 级}                  & \nwpu@securitylevel \\ \hline
                \makebox[\__nwpu_cover_detail_label_text_width:][s]{学\hfil 号}                  & \nwpu@uid           \\ \hline
            \end{tabular}\par                               % 排版基本信息表
            \vspace{\__nwpu_cover_after_detail_skip:}        %
            \fHei \sErhao
            \begin{tabular}[b]{@{}c@{}c@{}}
                \__nwpu_cover_title_row:nn
                    {
                      \__nwpu_cover_visual_bottom_cell:nnn
                        { \l__nwpu_cover_title_label_width_dim }
                        { \l__nwpu_cover_title_row_height_dim }
                        { 题目 }
                    }
                    { \nwpu@chs@coverTitleLineA }
                \__nwpu_cover_title_row:nn { } { \nwpu@chs@coverTitleLineB }
            \end{tabular}\par                                   % 排版结束
            \sWuhao \vspace{\__nwpu_cover_after_title_skip:}%
            \sSanhao \fSong                                 %
            \begin{tabular}[b]{@{}c@{}c@{}}
                \__nwpu_cover_author_row:n { \nwpu@chs@author }
            \end{tabular}\par                               % 排版作者信息
            \sWuhao \vspace{\__nwpu_cover_after_author_skip:}%
            \sSanhao \fSong
            \begin{tabular}[t]{@{}c@{}c@{}}
                \__nwpu_cover_info_row:nn
                    { \nwpu@chs@outerCoverFirstOption }
                    { \nwpu@chs@major }
                \__nwpu_cover_info_row:nn
                    { 指{\enspace}导{\enspace}教{\enspace}师 }
                    { \nwpu@chs@advisor\nwpu@chs@advisorAcademicRank }
                \__nwpu_cover_info_row:nn
                    { 培{\enspace}养{\enspace}单{\enspace}位 }
                    { \nwpu@chs@school }
                \__nwpu_cover_info_row:nn
                    { 申{\enspace}请{\enspace}日{\enspace}期 }
                    { \nwpu@chs@date }
            \end{tabular}                                   % 排版结束
            \vspace{\__nwpu_cover_after_info_skip:}         %
        \end{center}                                        %
    \end{titlepage} \fSong \normalsize \newpage \clearpage  %
}                                                           %
%%-----------------------------------------------------------------------------%
%% 中文内封
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \make@nwpu@chs@title {                          % 设置中文内封
    \thispagestyle{empty}                                   % 清空页面格式
    \settowidth{\l__nwpu_chstitle_hwidtha_dim}{\sSanhao\nwpu@chs@schoolname}
    \settowidth{\l__nwpu_chstitle_hwidthb_dim}{\sYihao\nwpu@chs@doctitle}
    % 测量宽度（注意使用相同字体 \sSanhao）
    \settowidth{\l__nwpu_author_dim}{\sSanhao\nwpu@chs@author}
    \settowidth{\l__nwpu_advisor_dim}{\sSanhao\nwpu@chs@advisor}
    \settowidth{\l__nwpu_major_dim}{\sSanhao\nwpu@chs@major}
    % 取最大值
    \dim_set:Nn \l__nwpu_maxname_dim { \l__nwpu_author_dim }
    \dim_compare:nNnT \l__nwpu_advisor_dim > \l__nwpu_maxname_dim
        { \dim_set:Nn \l__nwpu_maxname_dim { \l__nwpu_advisor_dim } }
    \dim_set:Nn \l__nwpu_chs_inner_title_value_dim
        { \l__nwpu_chs_inner_title_value_min_width_dim }
    \settowidth{\l__nwpu_chs_inner_title_line_dim}{\sErhao\nwpu@chs@coverTitleLineA}
    \dim_compare:nNnT \l__nwpu_chs_inner_title_line_dim > \l__nwpu_chs_inner_title_value_dim
        { \dim_set:Nn \l__nwpu_chs_inner_title_value_dim { \l__nwpu_chs_inner_title_line_dim } }
    \settowidth{\l__nwpu_chs_inner_title_line_dim}{\sErhao\nwpu@chs@coverTitleLineB}
    \dim_compare:nNnT \l__nwpu_chs_inner_title_line_dim > \l__nwpu_chs_inner_title_value_dim
        { \dim_set:Nn \l__nwpu_chs_inner_title_value_dim { \l__nwpu_chs_inner_title_line_dim } }
    \dim_set:Nn \l__nwpu_chs_inner_info_value_dim
        { \l__nwpu_chs_inner_info_value_min_width_dim }
    \dim_compare:nNnT \l__nwpu_major_dim > \l__nwpu_chs_inner_info_value_dim
        { \dim_set:Nn \l__nwpu_chs_inner_info_value_dim { \l__nwpu_major_dim } }
    \dim_compare:nNnT \l__nwpu_maxname_dim > \l__nwpu_chs_inner_info_value_dim
        { \dim_set:Nn \l__nwpu_chs_inner_info_value_dim { \l__nwpu_maxname_dim } }
    \begin{titlepage}                                       %
        \linespread{1.4}\selectfont                         %
        \begin{center}                                      %
            \fSong \sSanhao \par \vspace*{\__nwpu_chs_inner_top_skip:}%
            \makebox[\__nwpu_chs_inner_school_title_stretch:\l__nwpu_chstitle_hwidtha_dim][s]{\sSanhao\nwpu@chs@schoolname} \par
            \vspace*{\__nwpu_chs_inner_after_school_skip:}  %
            \makebox[\__nwpu_chs_inner_school_title_stretch:\l__nwpu_chstitle_hwidthb_dim][s]{\sYihao\nwpu@chs@doctitle} \par
            \vspace*{\__nwpu_chs_inner_after_doc_title_skip:}%
            \sSihao \par \vspace{\__nwpu_chs_inner_before_title_skip:}%
            \fSong \sErhao                                  % 排版标题
            \__nwpu_chs_inner_title: \fSong \sWuhao \par    % 排版结束
            \vspace{\__nwpu_chs_inner_after_title_skip:}     %
            \sSanhao \__nwpu_chs_inner_info: \\
            \fSong \sWuhao \par                             %
            \vspace{\__nwpu_chs_inner_after_info_skip:}      %
            \fSong \sSanhao \nwpu@chs@date                  %
        \end{center}                                        %
    \end{titlepage} \fSong \normalsize \newpage \clearpage  %
}                                                           %
%%-----------------------------------------------------------------------------%
%% 英文内封
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \make@nwpu@eng@title {                          % 设置英文内封
    \thispagestyle{empty}                                   % 清空页面格式
    \begin{titlepage}                                       %
        \begin{center}                                      %
            \fSong \sErhao \par \vspace*{\__nwpu_eng_inner_top_skip:}%
            \fEng \sErhao \textbf{Title:}~\sSanhao \nwpu@eng@title \par     %
            \fSong \sXiaoer \vspace{\__nwpu_eng_inner_after_title_skip:}%
            \fEng \sXiaosan \textbf{By} \par                %
            \fEng \sXiaosan \nwpu@eng@author \par  %
            \fEng \sXiaosan \textbf{Under~the~Supervision~of~\nwpu@eng@advisorAcademicRank} \\
            \fEng \sXiaosan \nwpu@eng@advisor \par %
            \fSong \sSanhao \vspace{\__nwpu_eng_inner_after_advisor_skip:}%
            \fEng \sXiaosan A~Dissertation~Submitted~to \\  %
            \fEng \sXiaosan {\nwpu@eng@schoolname} \\       %
            \fSong \sSanhao \vspace{\__nwpu_eng_inner_before_degree_skip:}%
            \fEng \sXiaosan {In~Partial~Fulfillment~of~The~Requirement} \\
            \fEng \sXiaosan {For~The~Degree~of} \\                      %
            \fEng \sXiaosan {{\nwpu@eng@degree}~of~\nwpu_if_master:TF{\nwpu@eng@major}{\textbf{\nwpu@eng@major}}}
            \fSong \sXiaosan \par \vspace{\__nwpu_eng_inner_after_degree_skip:}%
            \fEng \sXiaosan Xi'an,~P.R.~China \\            %
            \fEng \sXiaosan {\nwpu@eng@date}                %
        \end{center}                                        %
    \end{titlepage} \fSong \normalsize \newpage             %
    \thispagestyle{empty} \cleardoublepage                  %
}                                                           %
%%-----------------------------------------------------------------------------%
%% 本科封面
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \make@nwpu@bachelor@cover {                       % 设置本科封面
    \thispagestyle{empty}                                   % 清空页面格式
    \begin{titlepage}                                       %
        \begin{center}                                      %
            \vspace*{\__nwpu_bachelor_top_skip:}            %
            \includegraphics[width=\l__nwpu_bachelor_logo_width_dim]{nwpulogo.png}%
            \vskip \__nwpu_bachelor_after_logo_skip:        %
            \sChuhao\fSong {\bfseries 本科毕业设计（论文）}   %
            \vskip \__nwpu_bachelor_after_doc_title_skip:   %
                {                                               %
                    \sSanhao\fHei 题~~目 \hspace{\l__nwpu_bachelor_title_gap_dim}\coverunderline[\l__nwpu_bachelor_title_underline_width_dim]{\nwpu@chs@title} %
                }                                               %
            \vskip \__nwpu_bachelor_after_title_skip:       %
                {                                               %
                    \sSihao\fSong 专业名称\coverunderline[\l__nwpu_bachelor_info_underline_width_dim]{\nwpu@chs@major} %
                    \vskip \__nwpu_bachelor_info_row_skip:      %
                    \sSihao\fSong 学生姓名\coverunderline[\l__nwpu_bachelor_info_underline_width_dim]{\nwpu@chs@author} %
                    \vskip \__nwpu_bachelor_info_row_skip:      %
                    \sSihao\fSong 指导教师\coverunderline[\l__nwpu_bachelor_info_underline_width_dim]{\nwpu@chs@advisor} %
                    \vskip \__nwpu_bachelor_info_row_skip:      %
                    \sSihao\fSong 毕业时间\coverunderline[\l__nwpu_bachelor_info_underline_width_dim]{\nwpu@chs@date} %
                    \vfill                                      %
                }                                               %
        \end{center}                                        %
    \end{titlepage} \fSong \normalsize \newpage \clearpage  %
}                                                           %
%%-----------------------------------------------------------------------------%
%% 生成标题页
%%-----------------------------------------------------------------------------%
\cs_gset_protected:Npn \maketitle {
    \int_set:Nn \l__nwpu_hbadness_save_int { \hbadness }
    \int_set:Nn \l__nwpu_vbadness_save_int { \vbadness }
    \hbadness=10000
    \vbadness=10000
    \nwpu_if_bachelor:TF {                                      % 本科封面
        \make@nwpu@bachelor@cover                           %
    } {                                                      % 硕博封面
        \make@nwpu@coverpage                                % 封皮页
        \make@nwpu@chs@title                                % 中文内封
        \make@nwpu@eng@title                                % 英文内封
    }
    \hbadness=\l__nwpu_hbadness_save_int
    \vbadness=\l__nwpu_vbadness_save_int
}                                                           %
%%-----------------------------------------------------------------------------%
%% 彩色封底
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \make@nwpu@backcover {                          % 彩色封底
    \nwpu_if_colorcover:TF {
        \clearpage
        \thispagestyle{empty}
        \begin{tikzpicture}[remember picture,overlay]
            \node[at=(current page.center),inner sep=\l__nwpu_cover_background_inner_sep_dim] {
                \nwpu_if_phd:TF {
                    \includegraphics[width=\paperwidth,height=\paperheight]{backcover-phd.jpg}
                } {
                    \nwpu_if_bachelor:TF {
                        \includegraphics[width=\paperwidth,height=\paperheight]{backcover-bachelor.jpg}
                    } {
                        \nwpu_if_academic:TF {
                            \includegraphics[width=\paperwidth,height=\paperheight]{backcover-master-academic.jpg}
                        } {
                            \includegraphics[width=\paperwidth,height=\paperheight]{backcover-master-professional.jpg}
                        }
                    }
                }
            };
        \end{tikzpicture}
    }
}
\AtEndDocument{\make@nwpu@backcover}
%%=============================================================================%
%% 学位论文评阅人和答辩委员会名单
%%-----------------------------------------------------------------------------%
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \npu@text #1 {\relax\sDefault{#1}}
\cs_new_protected:Npn \expert #1 #2 #3 {\npu@text{#1} & \npu@text{#2} & \npu@text{#3} \\ }
\cs_new_protected:Npn \expertBlindReview {\expert{全盲评阅}{无}{无}}
\cs_new_protected:Npn \expertEmpty {\expert{}{}{}}
\cs_new_protected:Npn \fullBlindReview #1 {%
    \prg_replicate:nn {#1} {\expertBlindReview}%
    \prg_replicate:nn { \int_max:nn { 5 - #1 } { 0 } } {\expertEmpty}%
}
\cs_new_protected:Npn \defenseDate #1 {\sDefault\textbf{答辩日期}%
    & \multicolumn{3}{c}{\sDefault{#1}} \\ }
\cs_new_protected:Npn \defenseChair #1 #2 #3 {\sDefault\textbf{主席} & \expert{#1}{#2}{#3} }
\cs_new_protected:Npn \committeeMember #1 #2 #3 {\sDefault\textbf{委员} & \expert{#1}{#2}{#3} }
\cs_new_protected:Npn \defenseSecretary #1 #2 #3 {\sDefault\textbf{秘书} & \expert{#1}{#2}{#3} }
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \makeCommitteePage #1 {                         %
    \thispagestyle{empty}                                   % 清空页面格式
    \begin{titlepage}                                       %
        \linespread{1.2} \sXiaosan \par                     % 1.2 倍行距
        \vspace{\__nwpu_committee_top_skip:}                %
        \begin{center}                                      %
            \fHei \sSanhao {学位论文评阅人和答辩委员会名单} \par
            #1\relax                                        %
        \end{center}                                        %
    \end{titlepage} \normalsize \newpage             %
    \thispagestyle{empty} \cleardoublepage}                 %
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \reviewers #1 {                                 %
    \par \fSong \sDefault \vspace{\__nwpu_committee_before_reviewers_skip:}%
    \fSong \sSihao \vspace{\__nwpu_committee_reviewers_title_before_skip:}%
    \makebox[\linewidth][c]{\fHei \sSihao 学位论文评阅人名单} \par%
    \fSong \sSihao \vspace{\__nwpu_committee_reviewers_table_before_skip:}%
    \begin{tabular}{
        O{\l__nwpu_committee_review_name_width_dim}
        O{\l__nwpu_committee_review_rank_width_dim}
        O{\l__nwpu_committee_review_org_width_dim}
      }  %
        \sDefault \expert{\textbf{姓名}}{\textbf{职称}}{\textbf{工作单位}}
        #1\relax                                            %
    \end{tabular}\par}                                     %
%%-----------------------------------------------------------------------------%
\cs_new_protected:Npn \committee #1 #2 {                                 %
    \par \fSong \sDefault \vspace{\__nwpu_committee_before_defense_skip:}%
    \fSong \sSihao \vspace{\__nwpu_committee_defense_title_before_skip:}%
    \makebox[\linewidth][c]{\fHei \sSihao 答辩委员会名单} \par%
    \fSong \sSihao \vspace{\__nwpu_committee_defense_table_before_skip:}%
    \begin{tabular}{
        O{\l__nwpu_committee_role_width_dim}
        O{\l__nwpu_committee_name_width_dim}
        O{\l__nwpu_committee_rank_width_dim}
        O{\l__nwpu_committee_org_width_dim}
      }
        \defenseDate{#1} \sDefault\textbf{答辩委员会} & %   %
        \expert{\textbf{姓名}}{\textbf{职称}}{\textbf{工作单位}}
        #2\relax                                            %
    \end{tabular}\par}                                     %
%%=============================================================================%

\ExplSyntaxOff
